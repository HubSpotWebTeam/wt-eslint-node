{
  "name": "@hs-web-team/eslint-config-node",
  "version": "4.0.0",
  "description": "HubSpot Marketing WebTeam shared configurations for ESLint, Prettier, Stylelint, and Cypress",
  "main": "index.js",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./browser": "./browser.js",
    "./.prettierrc.json": "./.prettierrc.json",
    "./.stylelintrc.json": "./.stylelintrc.json",
    "./cypress.config": {
      "types": "./cypress.config.d.ts",
      "require": "./cypress.config.cjs"
    },
    "./cypress": {
      "types": "./cypress/index.d.ts",
      "default": "./cypress/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "cypress.config": [
        "./cypress.config.d.ts"
      ],
      "cypress": [
        "./cypress/index.d.ts"
      ]
    }
  },
  "scripts": {
    "lint": "npx eslint -c ./index.js *.js --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "add-prettier": "bin/add-prettier-scripts.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HubSpotWebTeam/wt-eslint-node.git"
  },
  "keywords": [
    "eslint",
    "prettier",
    "stylelint",
    "cypress",
    "hubspot",
    "config"
  ],
  "author": "Alessio Michelini & David Mooney",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HubSpotWebTeam/wt-eslint-node/issues"
  },
  "homepage": "https://github.com/HubSpotWebTeam/wt-eslint-node#readme",
  "dependencies": {
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "axe-core": "^4.11.4",
    "cypress-axe": "^1.7.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-formatter-checkstyle": "^9.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-gherkin": "4.0.0",
    "typescript-eslint": "^8.60.0"
  },
  "peerDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "cypress": "^15.16.0",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0"
  },
  "peerDependenciesMeta": {
    "stylelint": {
      "optional": true
    },
    "stylelint-config-standard": {
      "optional": true
    },
    "stylelint-config-standard-scss": {
      "optional": true
    },
    "cypress": {
      "optional": true
    }
  }
}
